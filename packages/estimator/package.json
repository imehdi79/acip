{
  "name": "@acip/estimator",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "@acip/source": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "nx": {
    "name": "estimator",
    "sourceRoot": "packages/estimator/src",
    "targets": {
      "build": {
        "executor": "@nx/js:swc",
        "outputs": [
          "{options.outputPath}"
        ],
        "options": {
          "outputPath": "packages/estimator/dist",
          "main": "packages/estimator/src/index.ts",
          "tsConfig": "packages/estimator/tsconfig.lib.json",
          "skipTypeCheck": true,
          "stripLeadingPaths": true
        }
      },
      "typecheck": {
        "executor": "nx:run-commands",
        "dependsOn": [
          "^build"
        ],
        "options": {
          "command": "bun x tsc -p packages/estimator/tsconfig.lib.json --noEmit",
          "cwd": "{workspaceRoot}"
        }
      },
      "test": {
        "executor": "nx:run-commands",
        "dependsOn": [
          "^build"
        ],
        "options": {
          "command": "bun test",
          "cwd": "packages/estimator"
        }
      }
    }
  },
  "dependencies": {
    "@acip/editor-core": "workspace:*",
    "@swc/helpers": "~0.5.18"
  }
}
