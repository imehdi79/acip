{
  "name": "@acip/editor-core",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "@acip/source": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "nx": {
    "name": "editor-core",
    "sourceRoot": "packages/editor-core/src",
    "targets": {
      "build": {
        "executor": "@nx/js:swc",
        "outputs": [
          "{options.outputPath}"
        ],
        "options": {
          "outputPath": "packages/editor-core/dist",
          "main": "packages/editor-core/src/index.ts",
          "tsConfig": "packages/editor-core/tsconfig.lib.json",
          "skipTypeCheck": true,
          "stripLeadingPaths": true
        }
      },
      "typecheck": {
        "executor": "nx:run-commands",
        "options": {
          "command": "bun x tsc -p packages/editor-core/tsconfig.lib.json --noEmit",
          "cwd": "{workspaceRoot}"
        }
      },
      "test": {
        "executor": "nx:run-commands",
        "options": {
          "command": "bun test",
          "cwd": "packages/editor-core"
        }
      }
    }
  },
  "dependencies": {
    "@swc/helpers": "~0.5.18"
  }
}
