# docker compose deployment — copy to .env next to docker-compose.yml (VPS)

# DNS A record for this name must point at the VPS
API_DOMAIN=acip-api.mehdify.com
# Let's Encrypt expiry notices go here
ACME_EMAIL=mehdi.rezaei879@gmail.com

POSTGRES_PASSWORD=change-me

# LLM + Whisper keys — configured once, never reach the browser
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# empty = allow all origins (current setting); later e.g. https://acip.pages.dev
CORS_ORIGIN=
