// Request log: what users asked for that the toolset couldn't deliver.
// Postgres from day one (user decision 2026-07-18) — same DB the future
// persistence/collaboration slice of editor-server will need anyway.
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Request {
  id        Int      @id @default(autoincrement())
  /// "missing-feature" | "missing-price"
  kind      String
  /// what the user asked for, in their words
  text      String
  /// optional detail: dimensions, level, materials involved
  context   String?
  /// "open" | "done"
  status    String   @default("open")
  createdAt DateTime @default(now())
}
