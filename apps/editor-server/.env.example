# editor-server configuration — copy to .env and fill in.
# Keys live here, on the server, once. They never reach the browser.

# LLM providers (the drafter proxies through /api/llm/<provider>)
ANTHROPIC_API_KEY=
# also used for /api/stt voice transcription (Whisper, any language)
OPENAI_API_KEY=

# SQLite file, relative to the prisma/ directory
DATABASE_URL="file:./data.db"

PORT=3000

# comma-separated origins allowed to call this server
# (e.g. https://acip-web-editor.you.workers.dev); empty = allow all
CORS_ORIGIN=
