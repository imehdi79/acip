{
  "name": "@acip/web-editor",
  "version": "0.0.1",
  "private": true,
  "dependencies": {
    "@acip/agent-drafter": "workspace:*",
    "@acip/editor-core": "workspace:*",
    "@acip/estimator": "workspace:*",
    "@tabler/icons-react": "^3.31.0",
    "three": "^0.170.0"
  },
  "devDependencies": {
    "@types/three": "^0.170.0"
  },
  "nx": {
    "targets": {
      "typecheck": {
        "executor": "nx:run-commands",
        "dependsOn": ["^build"],
        "options": {
          "command": "bun x tsc -p apps/web-editor/tsconfig.app.json --noEmit",
          "cwd": "{workspaceRoot}"
        }
      }
    }
  }
}
